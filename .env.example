# ================================================
# Teknao CRM - Variables de Entorno
# ================================================

# Backend
PORT=3001
NODE_ENV=development

# Database - SQLite (default)
# DB_PATH=./data/crm.db

# Database - PostgreSQL/Supabase (uncomment to use)
# DB_TYPE=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=crm
# DB_USER=postgres
# DB_PASSWORD=your_password

# Supabase (production)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-anon-key

# JWT
JWT_SECRET=your-super-secret-key-change-in-production

# Frontend
VITE_API_URL=/api